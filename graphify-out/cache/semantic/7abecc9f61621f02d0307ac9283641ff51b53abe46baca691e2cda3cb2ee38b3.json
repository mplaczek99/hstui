{"nodes": [{"id": "readme_hstui", "label": "hstui (hyprsunset TUI)", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Terminal UI for managing hyprsunset on Hyprland. Goal: make hyprsunset feel like a controllable desktop utility while fitting naturally into keyboard-driven Hyprland workflows. Targets users who want quick manual control, reusable profiles, and a simple TUI without a full graphical settings app."}, {"id": "readme_hyprsunset_daemon", "label": "hyprsunset daemon", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_bubbletea", "label": "Bubble Tea framework", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": "https://github.com/charmbracelet/bubbletea", "captured_at": null, "author": null, "contributor": null, "rationale": "TUI built on Bubble Tea (Model/Update pattern). Other TUI approaches were prototyped on tui/* branches before settling on Bubble Tea."}, {"id": "readme_profiles", "label": "hyprsunset profiles", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Profiles store temperature, gamma, and other fields written to ~/.config/hypr/hyprsunset.conf; the running daemon reads the config and applies the profile matching the current time."}, {"id": "readme_daemon_control", "label": "Daemon control via uwsm/pgrep/pkill", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Enabled checkbox launches hyprsunset through 'uwsm app' and stops it by terminating the hyprsunset process; runtime state checked via pgrep and killed via pkill."}], "edges